# ----------------------------------------------------------------------------
# Project Strand — environment
# Copy to .env (local) or set these in your host's dashboard (Vercel/Railway/…)
# ----------------------------------------------------------------------------

# Session signing secret — REQUIRED in production. Generate a long random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=dev-secret-change-me

# Public base URL of the app (used in invite/reset email links)
APP_URL=http://localhost:3000

# --- Database --------------------------------------------------------------
# LOCAL DEV: leave DATABASE_URL unset → the app uses PGlite (./.pgdata). 
# PRODUCTION: set DATABASE_URL to a managed Postgres (Neon, Supabase, Railway,
# Render, RDS). Use the POOLED connection string where the provider offers one.
#   DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# DATABASE_URL=

# --- Email -----------------------------------------------------------------
# console (default) just logs emails. For real delivery choose ONE provider:
#
# (a) Resend (API):
#   EMAIL_PROVIDER=resend
#   RESEND_API_KEY=re_xxx
#   EMAIL_FROM="Project Strand <noreply@yourdomain.com>"
#
# (b) SMTP — e.g. Google Workspace, cPanel/HostGator, Office365, etc.:
#   EMAIL_PROVIDER=smtp
#   SMTP_HOST=mail.yourdomain.com      # cPanel: the mail server hostname
#   SMTP_PORT=465                      # 465 = SSL (secure), 587 = STARTTLS
#   SMTP_SECURE=true                   # true for 465, false for 587
#   SMTP_USER=noreply@yourdomain.com   # the FULL email address
#   SMTP_PASS=the-mailbox-password
#   EMAIL_FROM=Project Strand <noreply@yourdomain.com>   # NOTE: no surrounding quotes
#   SMTP_TLS_INSECURE=true             # only if the host's TLS cert mismatches
#
# (b1) GOOGLE WORKSPACE (recommended for makepistat.org):
#   EMAIL_PROVIDER=smtp
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=admin@makepistat.org
#   SMTP_PASS=<16-char App Password>   # Google Account → Security → App passwords (requires 2-Step Verification)
#   EMAIL_FROM=Project Strand <admin@makepistat.org>
#
# Platform contact + where upgrade requests are sent (defaults to admin@makepistat.org):
#   SYSTEM_ADMIN_EMAIL=admin@makepistat.org
#   CONTACT_EMAIL=admin@makepistat.org
EMAIL_PROVIDER=console

# --- File storage ----------------------------------------------------------
# local (default) writes to ./.uploads — fine on a host with a persistent disk
# (Railway/Render). On Vercel (ephemeral FS) configure S3/R2 in storage.ts.
STORAGE_PROVIDER=local

# --- Commercial / trial ----------------------------------------------------
# Length of the free trial for new organisations, in days (default 90 = ~3 months)
TRIAL_DAYS=90
